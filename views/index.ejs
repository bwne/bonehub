<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bonecan Scripts | Roblox Arşivi</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header>
        <div class="logo">Bonecan <span>Scripts</span></div>
        <nav>
            <a href="/">Ana Sayfa</a>
            <a href="/admin">Yönetim Paneli</a>
        </nav>
    </header>

    <div class="container">

        <!-- Eğer veritabanı bağlantısı henüz kurulmadıysa uyarı mesajı gösterir -->
        <% if (!dbConnected) { %>
            <div class="db-alert">
                <strong>Bağlantı Uyarısı:</strong> MongoDB Atlas bulut veritabanına şu an bağlanılamadı. Lütfen MongoDB Atlas panelinden <strong>Network Access</strong> alanına gidip IP iznini <code>0.0.0.0/0</code> (Her Yerden Erişim) olarak ayarladığınızdan ve <code>server.js</code> içerisindeki şifrenizin doğru olduğundan emin olun.
            </div>
        <% } %>
        
        <form action="/" method="GET" class="search-filter-section">
            <div class="search-box">
                <input type="text" name="search" placeholder="Script ara (Örn: Blox Fruits)..." value="<%= searchQuery || '' %>">
            </div>
            
            <select name="category" class="category-filter" onchange="this.form.submit()">
                <option value="">Tüm Oyunlar</option>
                <% categories.forEach(cat => { %>
                    <option value="<%= cat._id %>" <%= selectedCategory == cat._id.toString() ? 'selected' : '' %> >
                        <%= cat.name %>
                    </option>
                <% }) %>
            </select>
            
            <% if(searchQuery || selectedCategory) { %>
                <a href="/" style="padding: 15px; color: #ef4444;">Filtreleri Temizle</a>
            <% } %>
        </form>

        <h2>Son Yüklenen Scriptler</h2>
        <br>

        <div class="script-grid">
            <% if(scripts.length === 0) { %>
                <p>Gösterilecek script bulunamadı.</p>
            <% } %>

            <% scripts.forEach(script => { %>
                <div class="script-card">
                    <img src="<%= script.image %>" alt="<%= script.title %>" class="card-image">
                    <div class="card-content">
                        <div class="card-category"><%= script.category ? script.category.name : 'Genel' %></div>
                        <div class="card-title"><%= script.title %></div>
                        <div class="card-desc"><%= script.description %></div>
                        <a href="/script/<%= script._id %>" class="btn-read">Devamını Oku &rarr;</a>
                    </div>
                </div>
            <% }) %>
        </div>

    </div>

</body>
</html>
